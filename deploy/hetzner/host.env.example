# Copy to deploy/hetzner/host.env (gitignored) and fill in.

# The server's public IP (printed by provision.sh, or from the Hetzner console).
HETZNER_HOST=

# SSH login user. Hetzner cloud images default to root.
HETZNER_USER=root

# Private key to use for SSH (optional — omit to use your default key/agent).
# HETZNER_SSH_KEY=~/.ssh/id_ed25519

# Where the bot lives on the server.
REMOTE_DIR=/opt/delta-bot
