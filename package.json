{
  "name": "delta-neutral-lp-bot",
  "version": "0.1.0",
  "description": "Delta-neutral liquidity provision bot for Solana (Meteora DLMM + Drift)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:local": "NODE_ENV=localnet tsx src/test/local-meteora-test.ts",
    "test:mainnet": "NODE_ENV=mainnet tsx src/test/mainnet-meteora-test.ts",
    "test:integration": "NODE_ENV=mainnet tsx src/test/integration-test.ts",
    "find-pools": "NODE_ENV=mainnet tsx scripts/find-mainnet-pools.ts",
    "auto-tune": "NODE_ENV=mainnet tsx src/cli/auto-tune.ts",
    "auto-tune:watch": "NODE_ENV=mainnet tsx src/cli/auto-tune.ts --watch",
    "localnet:start": "./scripts/start-localnet-mainnet-fork.sh",
    "localnet:stop": "pkill solana-test-validator",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "api": "bun run src/api/hono-server.ts",
    "ui": "cd ui && bun run server.ts",
    "dev": "concurrently \"npm run api\" \"npm run ui\" --names \"API,UI\" --prefix-colors \"cyan,magenta\""
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@meteora-ag/dlmm": "^1.7.5",
    "@pythnetwork/client": "^2.22.1",
    "@pythnetwork/pyth-solana-receiver": "^0.12.0",
    "@solana/web3.js": "^1.95.8",
    "@switchboard-xyz/on-demand": "^3.1.2",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "hono": "^4.10.4",
    "solana-agent-kit": "^2.0.10",
    "undici": "^7.16.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/bs58": "^4.0.4",
    "@types/node": "^22.10.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
