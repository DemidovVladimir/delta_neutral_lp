{
  "name": "meteora-dlmm-lp-bot",
  "version": "0.1.0",
  "description": "Automated liquidity provision bot for Meteora DLMM on Solana with auto-tune rebalancing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:mainnet": "tsx src/test/mainnet-meteora-test.ts",
    "test:integration": "tsx src/test/integration-test.ts",
    "find-pools": "tsx scripts/find-mainnet-pools.ts",
    "auto-tune": "tsx src/cli/auto-tune.ts",
    "auto-tune:watch": "tsx src/cli/auto-tune.ts --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "api": "bun run src/api/hono-server.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:rebuild": "docker compose up -d --build",
    "deploy:gcp:setup": "cd deploy/gcp/pulumi && npm install",
    "deploy:gcp:config": "cd deploy/gcp/pulumi && pulumi config",
    "deploy:gcp:preview": "cd deploy/gcp/pulumi && pulumi preview",
    "deploy:gcp:up": "cd deploy/gcp/pulumi && pulumi up",
    "deploy:gcp:destroy": "cd deploy/gcp/pulumi && pulumi destroy",
    "deploy:gcp:logs": "cd deploy/gcp/pulumi && pulumi stack output logsCommand | bash",
    "deploy:gcp:ssh": "cd deploy/gcp/pulumi && pulumi stack output sshCommand | bash",
    "deploy:gcp:status": "cd deploy/gcp/pulumi && pulumi stack output",
    "deploy:gcp:stop": "cd deploy/gcp/pulumi && pulumi stack output stopCommand | bash",
    "deploy:gcp:start": "cd deploy/gcp/pulumi && pulumi stack output startCommand | bash"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@google-cloud/logging": "^11.2.1",
    "@meteora-ag/dlmm": "^1.7.5",
    "@pythnetwork/client": "^2.22.1",
    "@pythnetwork/pyth-solana-receiver": "^0.12.0",
    "@solana/signers": "^5.0.0",
    "@solana/transaction-messages": "^5.0.0",
    "@solana/transactions": "^5.0.0",
    "@solana/web3.js": "^1.95.8",
    "@switchboard-xyz/on-demand": "^3.1.2",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "hono": "^4.10.4",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "undici": "^7.16.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/bs58": "^4.0.4",
    "@types/node": "^22.10.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
