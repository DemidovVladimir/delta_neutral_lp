# =============================================================================
# Delta-Neutral LP Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Solana RPC URL (use a premium RPC provider for production)
# Examples:
#   - Helius: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   - QuickNode: https://YOUR_ENDPOINT.quiknode.pro/YOUR_KEY/
#   - Triton: https://YOUR_ENDPOINT.rpcpool.com/YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

# Private key for bot wallet (base58 encoded string or comma-separated bytes)
# Generate with: solana-keygen new --outfile ~/.config/solana/bot-wallet.json
# Get base58: bs58 encode < ~/.config/solana/bot-wallet.json
# KEEP THIS SECRET! Never commit or share!
PRIVATE_KEY=

# =============================================================================
# METEORA POSITION SETUP (Choose ONE approach)
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# OPTION 1: AUTO-CREATE POSITIONS (Recommended - Zero Manual Setup!)
# ──────────────────────────────────────────────────────────────────────────────
# Enable automatic position creation on first run
AUTO_CREATE_POSITIONS=true

# Meteora DLMM pool address (e.g., SOL/USDC pool)
# Find pools at: https://app.meteora.ag/pools
# Example SOL/USDC pool: LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo
METEORA_POOL_ADDRESS=

# Initial deposit amounts (will be used to create position)
INITIAL_DEPOSIT_SOL=10
INITIAL_DEPOSIT_USDC=1000

# Price range in basis points from current price
# Example: -500 = -5%, +500 = +5% from current SOL price
# Tighter ranges = more fees but need rebalancing more often
# Wider ranges = less fees but more stable
PRICE_RANGE_BPS_LOWER=-500
PRICE_RANGE_BPS_UPPER=500

# ──────────────────────────────────────────────────────────────────────────────
# OPTION 2: USE EXISTING POSITIONS (Manual Setup Required)
# ──────────────────────────────────────────────────────────────────────────────
# Set AUTO_CREATE_POSITIONS=false and provide existing position details
# AUTO_CREATE_POSITIONS=false

# LP owner wallet address (public key)
# LP_OWNER=

# Meteora position NFT mint addresses (comma-separated for multiple positions)
# Find these in your wallet or from Meteora UI
# METEORA_POSITION_MINTS=

# =============================================================================
# DRIFT CONFIGURATION
# =============================================================================

# Drift market index for SOL-PERP
# Typically 0 for SOL-PERP on Drift
DRIFT_MARKET_SOL_PERP=0

# =============================================================================
# RISK PARAMETERS
# =============================================================================

# Maximum delta (in SOL) before triggering rebalance
# Example: 2 means bot will rebalance when |LP_SOL - SHORT_SOL| >= 2
DELTA_THRESHOLD_SOL=2

# Minimum collateral ratio (collateral / notional)
# Example: 0.15 = 15% minimum collateral
MIN_COLLATERAL_RATIO=0.15

# Maximum short position size in USD notional
# Example: 12000 = max $12,000 short position
MAX_SHORT_NOTIONAL_USD=12000

# Maximum acceptable funding rate (basis points per day)
# Example: 80 = 0.8% per day funding rate cap
FUNDING_RATE_CAP_BPS=80

# =============================================================================
# EXECUTION PARAMETERS
# =============================================================================

# Enable Jito bundles for emergency flows
USE_JITO=true

# Jito relay URL
# Mainnet: https://mainnet.block-engine.jito.wtf/api/v1/bundles
# Devnet: https://bundles-api-rest.devnet.jito.wtf/api/v1/bundles
JITO_RELAY_URL=

# Priority tip in lamports
# Higher = better chance of inclusion during congestion
# Examples: 10000 (low), 50000 (medium), 100000 (high), 500000 (very high)
PRIORITY_TIP_LAMPORTS=80000

# Maximum compute units per transaction
# Solana limit is 1.4M, leave headroom for safety
MAX_COMPUTE_UNITS=1200000

# =============================================================================
# LOOP PARAMETERS (Optional - defaults provided)
# =============================================================================

# Hedge loop interval in milliseconds
# Default: 15000 (15 seconds)
# Adjust based on volatility and RPC rate limits
HEDGE_LOOP_INTERVAL_MS=15000

# Maximum retries for failed operations
# Default: 3
MAX_RETRIES=3

# =============================================================================
# LOGGING (Optional)
# =============================================================================

# Log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# Node environment: development | production
# Default: development
NODE_ENV=development
