# =============================================================================
# Meteora DLMM LP Bot - Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# All operations run on Solana MAINNET
#
# ⚠️  IMPORTANT: This .env file is the SINGLE SOURCE OF TRUTH for all configuration
#     Both local development and production (GCP) use these environment variables
#     There is no separate "static config" file - everything is controlled here
#
# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Mainnet RPC
RPC_URL=https://mainnet.helius-rpc.com/?api-key=<api_key_here>

# Private key - SAME AS LOCAL FOR TESTING
PRIVATE_KEY=<private_key_here>

LP_OWNER=<Funder_public_key_here>   



# =============================================================================
# METEORA POSITION SETUP
# =============================================================================

# Auto-create positions on first run (default: false)
# If true, bot will create a new position automatically
# If false, you must provide existing position mints via METEORA_POSITION_MINTS
AUTO_CREATE_POSITIONS=true

# Pool: SOL-USDC with bin step 4, high liquidity ($2.7M), 1262% APY
METEORA_POOL_ADDRESS=5rCf1DM8LjKTw4YqhnoLcngyZYeNnQqztScTogYHAS6

# Balanced position (0.01 SOL + 1.6 USDC = ~$3.20 total)
INITIAL_DEPOSIT_SOL=0.01
INITIAL_DEPOSIT_USDC=1.6

# Meteora strategy type for liquidity distribution
# Options: "spot" (balanced), "curve" (weighted), "bidask" (one-sided)
# Default: "spot" - balanced liquidity distribution across bins
METEORA_STRATEGY_TYPE=spot

# =============================================================================
# AUTO-TUNE PARAMETERS (Optional - for automated position rebalancing)
# =============================================================================

# Enable auto-tune mode for automatic position rebalancing
AUTO_TUNE_ENABLED=false

# Number of bins for concentrated liquidity (default: 20)
# Lower = more concentrated, higher capital efficiency but more frequent rebalances
AUTO_TUNE_BIN_COUNT=20

# How often to check position balance in milliseconds (default: 30000 = 30s)
AUTO_TUNE_CHECK_INTERVAL_MS=30000

# Imbalance threshold as decimal (default: 0.8 = 80%)
# Triggers rebalance when position becomes >80% SOL or >80% USDC
AUTO_TUNE_IMBALANCE_THRESHOLD=0.8

# Deposit token to use for position sizing (SOL or USDC)
# Auto-tune will use this token amount + claimed fees to calculate balanced position
AUTO_TUNE_DEPOSIT_TOKEN=SOL

# Amount of the deposit token to use for each position (default: 1.0)
# Example: 1 SOL will be used to calculate balanced position at current price
# Claimed fees are auto-compounded on top of this amount
AUTO_TUNE_DEPOSIT_AMOUNT=1.0

# Maximum retries for position creation (default: 3)
# Simple exponential backoff retry logic for network errors
# Swap is executed BEFORE position creation if needed (not bundled)
AUTO_TUNE_MAX_RETRIES=3

# =============================================================================
# GENERAL RETRY CONFIGURATION
# =============================================================================

# Maximum retries for general operations (default: 3)
# Applies to non-auto-tune operations
MAX_RETRIES=3

# =============================================================================
# WALLET RESERVES
# =============================================================================

# Minimum SOL balance to always keep in wallet (default: 0.2)
# This is your "last reserve" that will NEVER be used for positions or swaps
# Useful as emergency fund for manual operations or unexpected fees
MINIMUM_WALLET_BALANCE_SOL=0.2

# Temporary reserve for position creation rent and fees (default: 0.1)
# This covers:
# - Position rent (~0.057 SOL, reclaimable when position is closed)
# - Transaction fees (~0.03-0.05 SOL for transactions)
# This is temporary and gets used during position creation, then partially reclaimed
RENT_RESERVE_SOL=0.1

# =============================================================================
# SWAP PARAMETERS (Jupiter Integration)
# =============================================================================

# Enable Jupiter swap functionality (default: true)
# Used when wallet has insufficient balance for position creation
# Swap is executed as separate transaction BEFORE position creation
# Pre-flight balance check determines if swap is needed
SWAP_ENABLED=true

# Slippage tolerance in basis points (default: 50 = 0.5%)
# Higher slippage = more tolerance for price movement during swap
# This is passed to Jupiter API for swap execution
SWAP_SLIPPAGE_BPS=50

# Additional slippage buffer percentage (default: 3.0%)
# Applied on top of calculated swap amount to account for price impact
# Example: 3.0 = adds 3% to swap amount
# Higher values = more headroom for volatile/thin-liquidity moments; surplus is
# absorbed by the position rather than lost. Lower values save a small amount
# per swap but raise the rate of Phase 2 retries when actual impact spikes.
SWAP_SLIPPAGE_BUFFER_PCT=3.0

# Threshold above which a high-impact swap warning fires (default: 1.0%)
# After each successful swap, the bot compares Jupiter's reported priceImpactPct
# against this value. Exceedances are logged loudly so the operator can notice
# pools that have grown thinner than the buffer is sized for.
SWAP_HIGH_IMPACT_WARNING_PCT=1.0

# =============================================================================
# API SERVER (Hono) — guards for mutating endpoints
# =============================================================================
# These apply only to the optional Hono REST API started by `pnpm api`.
# The auto-tune CLI (`pnpm auto-tune`) does NOT go through the API server,
# so leaving these unset only affects HTTP clients.

# Shared secret required on POST /api/positions/* via the X-API-Key header.
# When unset, mutating endpoints fail-close (return 503) so an exposed port
# can never move funds without explicit auth. GET endpoints remain available.
# Pick a long random string: `openssl rand -hex 32`
# API_KEY=

# Comma-separated allowlist of CORS origins for the API. Defaults to common
# local dev ports. Production should set this to the exact origin(s) of the
# UI you ship.
# API_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Max mutating POST requests per remote IP per minute (default: 10). Bumps
# return HTTP 429 with a Retry-After header.
# API_RATE_LIMIT_PER_MIN=10

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info
