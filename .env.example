# =============================================================================
# Delta-Neutral LP Bot - LOCAL Configuration
# =============================================================================
# CAUTION: This is for FAKE with FAKE funds!

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Mainnet RPC
RPC_URL=https://mainnet.helius-rpc.com/?api-key=<api_key_here>

# Private key - SAME AS LOCAL FOR TESTING
PRIVATE_KEY=<private_key_here>

LP_OWNER=<Funder_public_key_here>   



# =============================================================================
# METEORA POSITION SETUP - BALANCED POSITION
# =============================================================================

# Pool: SOL-USDC with bin step 4, high liquidity ($2.7M), 1262% APY
METEORA_POOL_ADDRESS=5rCf1DM8LjKTw4YqhnoLcngyZYeNnQqztScTogYHAS6

# Balanced position (0.01 SOL + 1.6 USDC = ~$3.20 total)
INITIAL_DEPOSIT_SOL=0.01
INITIAL_DEPOSIT_USDC=1.6

# Price range ±1% (~51 bins) - Fits within 70-bin limit
# At ~$163: range $161.30 - $164.56 (covers 2% total price movement)
# Meteora DLMM enforces 70-bin max width for this pool (bin step 4)
PRICE_RANGE_BPS_LOWER=-100
PRICE_RANGE_BPS_UPPER=100

# =============================================================================
# DRIFT CONFIGURATION
# =============================================================================

DRIFT_MARKET_SOL_PERP=0

# =============================================================================
# RISK PARAMETERS
# =============================================================================

DELTA_THRESHOLD_SOL=0.05
MIN_COLLATERAL_RATIO=0.15
MAX_SHORT_NOTIONAL_USD=100
FUNDING_RATE_CAP_BPS=80

# =============================================================================
# EXECUTION PARAMETERS
# =============================================================================

# Jito bundling (MEV protection) - DISABLED BY DEFAULT due to DNS issues
# Set to true to enable Jito bundling (requires working DNS resolution for jito.wtf)
# Note: Jito API DNS (bundles-api-rest.jito.wtf) may not resolve on some networks
# When enabled, falls back to static tip values if API is unavailable
USE_JITO=false

# Jito configuration (only used if USE_JITO=true)
JITO_RELAY_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# Transaction parameters
# For Jito bundles: Priority fees are OPTIONAL (Jito tip provides priority)
# For single txs: Use moderate priority fees
# Typical 2025 values: 25,000-100,000 micro-lamports per CU
# Formula: priorityFee = computeUnits × microLamportsPerCU / 1,000,000
PRIORITY_FEE_MICRO_LAMPORTS=50000
MAX_COMPUTE_UNITS=600000

# =============================================================================
# AUTO-TUNE PARAMETERS (Optional - for automated position rebalancing)
# =============================================================================

# Enable auto-tune mode for automatic position rebalancing
AUTO_TUNE_ENABLED=false

# Number of bins for concentrated liquidity (default: 20)
# Lower = more concentrated, higher capital efficiency but more frequent rebalances
AUTO_TUNE_BIN_COUNT=20

# How often to check position balance in milliseconds (default: 30000 = 30s)
AUTO_TUNE_CHECK_INTERVAL_MS=30000

# Imbalance threshold as decimal (default: 0.9 = 90%)
# Triggers rebalance when position becomes >90% SOL or >90% USDC
AUTO_TUNE_IMBALANCE_THRESHOLD=0.9

# Deposit token to use for position sizing (SOL or USDC)
# Auto-tune will use this token amount + claimed fees to calculate balanced position
AUTO_TUNE_DEPOSIT_TOKEN=SOL

# Amount of the deposit token to use for each position (default: 1.0)
# Example: 1 SOL will be used to calculate balanced position at current price
# Claimed fees are auto-compounded on top of this amount
AUTO_TUNE_DEPOSIT_AMOUNT=1.0

# Maximum retries for position creation (default: 3)
# Includes retries with swap bundling and escalating Jito tips
AUTO_TUNE_MAX_RETRIES=3

# =============================================================================
# SWAP PARAMETERS (Jupiter Integration)
# =============================================================================

# Enable Jupiter swap functionality (default: true)
# Used for auto-balancing when position creation fails due to insufficient token balance
SWAP_ENABLED=true

# Slippage tolerance in basis points (default: 50 = 0.5%)
# Higher slippage = more tolerance for price movement during swap
SWAP_SLIPPAGE_BPS=50

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info
NODE_ENV=production
